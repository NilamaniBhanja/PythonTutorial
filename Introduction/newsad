[Route("api/quotes/check")]
public HttpResponseMessage ProcessQuote(string quoteNumber)
{
    bool isLocked = QuoteManager.IsDuplicate(quoteNumber);

    if (isLocked)
    {
        return Request.CreateResponse(HttpStatusCode.Conflict, 
            "This quote is locked for 5 minutes. Please try again later.");
    }

    return Request.CreateResponse(HttpStatusCode.OK, "Quote accepted.");
}
