using System;
using System.Data.SqlClient;
using System.Configuration;

public static class QuoteManager
{
    // Make sure "MyDbConn" is defined in your web.config
    private static readonly string connectionString = ConfigurationManager.ConnectionStrings["MyDbConn"].ConnectionString;

    public static bool IsDuplicate(string quoteNumber)
    {
        using (SqlConnection conn = new SqlConnection(connectionString))
        {
            // We use an INSERT. If the ID exists, SQL throws an exception.
            // This is the most reliable way to handle "distributed" locks in SQL.
            string query = "INSERT INTO QuoteCache (QuoteNumber) VALUES (@quote)";

            using (SqlCommand cmd = new SqlCommand(query, conn))
            {
                cmd.Parameters.AddWithValue("@quote", quoteNumber);

                try
                {
                    conn.Open();
                    cmd.ExecuteNonQuery();
                    return false; // Inserted successfully, not a duplicate
                }
                catch (SqlException ex)
                {
                    // Error 2627 is Primary Key violation (Duplicate)
                    if (ex.Number == 2627 || ex.Number == 2601)
                    {
                        return true; 
                    }
                    throw; // Some other SQL error occurred
                }
            }
        }
    }
}

using System.Net;
using System.Net.Http;
using System.Web.Http;

public class QuoteController : ApiController
{
    [HttpPost]
    [Route("api/quotes/submit")]
    public HttpResponseMessage SubmitQuote(string quoteNumber)
    {
        if (string.IsNullOrEmpty(quoteNumber))
        {
            return Request.CreateResponse(HttpStatusCode.BadRequest, "Quote number is required.");
        }

        // Check if duplicate using our SQL manager
        bool exists = QuoteManager.IsDuplicate(quoteNumber);

        if (exists)
        {
            // 409 Conflict is the standard response for a duplicate resource
            return Request.CreateResponse(HttpStatusCode.Conflict, "This quote has already been processed.");
        }

        // --- Your Business Logic Here ---
        
        return Request.CreateResponse(HttpStatusCode.OK, "Quote submitted successfully.");
    }
}

using System;
using System.Data.SqlClient;
using System.Configuration;

public static class QuoteManager
{
    private static readonly string connectionString = ConfigurationManager.ConnectionStrings["MyDbConn"].ConnectionString;

    public static bool IsDuplicate(string quoteNumber)
    {
        using (SqlConnection conn = new SqlConnection(connectionString))
        {
            conn.Open();
            
            // 1. Delete any records that have expired (older than 5 minutes)
            string deleteQuery = "DELETE FROM QuoteCache WHERE ExpiryTime <= @Now";
            using (SqlCommand delCmd = new SqlCommand(deleteQuery, conn))
            {
                delCmd.Parameters.AddWithValue("@Now", DateTime.Now);
                delCmd.ExecuteNonQuery();
            }

            // 2. Attempt to insert the new quote
            string insertQuery = "INSERT INTO QuoteCache (QuoteNumber, ExpiryTime) VALUES (@quote, @expiry)";
            using (SqlCommand insCmd = new SqlCommand(insertQuery, conn))
            {
                insCmd.Parameters.AddWithValue("@quote", quoteNumber);
                // Set expiry to 5 minutes from now
                insCmd.Parameters.AddWithValue("@expiry", DateTime.Now.AddMinutes(5));

                try
                {
                    insCmd.ExecuteNonQuery();
                    return false; // Success! Not a duplicate.
                }
                catch (SqlException ex)
                {
                    // Primary Key violation means it's still in the 5-minute window
                    if (ex.Number == 2627 || ex.Number == 2601)
                    {
                        return true; 
                    }
                    throw;
                }
            }
        }
    }
}

