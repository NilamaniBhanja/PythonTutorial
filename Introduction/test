            {
                for (int i = 0; i < PremiumObj.lstPreviousAddonDetails.Count; i++)
                {
                    if (PremiumObj.lstPreviousAddonDetails[i].IsEngineSafeOptedInPrevPolicy && dbRenewalDump.Engine_Safe_Cover_Ex == null)
                    {
                        return "EngineSafe is not present in previous policy,unselect the cover";
                    }
                    if (PremiumObj.lstPreviousAddonDetails[i].IsGAPCoverOptedInPrevPolicy && dbRenewalDump.GAP_Value_Cover_EX == null)
                    {
                        return "Gap Cover is not present in previous policy,unselect the cover";
                    }
                    if (PremiumObj.lstPreviousAddonDetails[i].IsNilDepreicationOptedInPrevPolicy && dbRenewalDump.Depreciation_Cover_EX == null)
                    {
                        return "Nil dep is not present in previous policy,unselect the cover";
                    }
                }
            }
            return string.Empty;
        }
