using System;
using System.Runtime.Caching;

public static class QuoteProcessingManager
{
    private static readonly MemoryCache Cache = MemoryCache.Default;

    private const int ExpiryMinutes = 2;

    public static bool TryStartProcessing(string quoteNumber)
    {
        string cacheKey = GetKey(quoteNumber);

        var policy = new CacheItemPolicy
        {
            AbsoluteExpiration = DateTimeOffset.Now.AddMinutes(ExpiryMinutes)
        };

        // Add returns false if key already exists
        return Cache.Add(cacheKey, true, policy);
    }

    public static void FinishProcessing(string quoteNumber)
    {
        string cacheKey = GetKey(quoteNumber);

        if (Cache.Contains(cacheKey))
        {
            Cache.Remove(cacheKey);
        }
    }

    private static string GetKey(string quoteNumber)
    {
        return $"FULL_QUOTE_{quoteNumber}";
    }
}


[HttpPost]
public async Task<IHttpActionResult> ProcessQuote(QuoteRequest request)
{
    if (!request.IsFullQuote)
    {
        return Ok("Normal request");
    }

    bool started = QuoteProcessingManager
        .TryStartProcessing(request.QuoteNumber);

    if (!started)
    {
        return Content(
            HttpStatusCode.Conflict,
            "Quote already processing."
        );
    }

    try
    {
        await ProcessFullQuote(request);

        return Ok("Processed successfully");
    }
    catch (Exception ex)
    {
        return InternalServerError(ex);
    }
    finally
    {
        // Optional:
        // remove immediately after completion
        QuoteProcessingManager
            .FinishProcessing(request.QuoteNumber);
    }
}
