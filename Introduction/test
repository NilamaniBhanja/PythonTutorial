CREATE TABLE dbo.QuoteCache
(
    QuoteNumber NVARCHAR(100) PRIMARY KEY,
    CreatedDate DATETIME NOT NULL DEFAULT(GETDATE()),
    ExpiryDate DATETIME NOT NULL
);

using System;
using System.Configuration;
using System.Data.SqlClient;
using System.Threading.Tasks;

namespace MyWebApi.Services
{
    public class QuoteCacheService
    {
        private readonly string _connectionString;

        public QuoteCacheService()
        {
            _connectionString =
                ConfigurationManager
                .ConnectionStrings["CacheDb"]
                .ConnectionString;
        }

        // SAVE QUOTE NUMBER
        public async Task SaveAsync(string quoteNumber)
        {
            using (SqlConnection con =
                new SqlConnection(_connectionString))
            {
                string query = @"
IF NOT EXISTS
(
    SELECT 1
    FROM QuoteCache
    WHERE QuoteNumber = @QuoteNumber
)
BEGIN
    INSERT INTO QuoteCache
    (
        QuoteNumber,
        ExpiryDate
    )
    VALUES
    (
        @QuoteNumber,
        DATEADD(HOUR, 1, GETDATE())
    )
END";

                SqlCommand cmd =
                    new SqlCommand(query, con);

                cmd.Parameters.AddWithValue(
                    "@QuoteNumber",
                    quoteNumber);

                await con.OpenAsync();

                await cmd.ExecuteNonQueryAsync();
            }
        }

        // CHECK EXISTS
        public async Task<bool> ExistsAsync(string quoteNumber)
        {
            using (SqlConnection con =
                new SqlConnection(_connectionString))
            {
                string query = @"
SELECT COUNT(1)
FROM QuoteCache
WHERE QuoteNumber = @QuoteNumber
AND ExpiryDate > GETDATE()";

                SqlCommand cmd =
                    new SqlCommand(query, con);

                cmd.Parameters.AddWithValue(
                    "@QuoteNumber",
                    quoteNumber);

                await con.OpenAsync();

                int count =
                    Convert.ToInt32(
                        await cmd.ExecuteScalarAsync());

                return count > 0;
            }
        }

        // REMOVE
        public async Task RemoveAsync(string quoteNumber)
        {
            using (SqlConnection con =
                new SqlConnection(_connectionString))
            {
                string query = @"
DELETE
FROM QuoteCache
WHERE QuoteNumber = @QuoteNumber";

                SqlCommand cmd =
                    new SqlCommand(query, con);

                cmd.Parameters.AddWithValue(
                    "@QuoteNumber",
                    quoteNumber);

                await con.OpenAsync();

                await cmd.ExecuteNonQueryAsync();
            }
        }

        // CLEAN EXPIRED CACHE
        public async Task RemoveExpiredAsync()
        {
            using (SqlConnection con =
                new SqlConnection(_connectionString))
            {
                string query = @"
DELETE
FROM QuoteCache
WHERE ExpiryDate < GETDATE()";

                SqlCommand cmd =
                    new SqlCommand(query, con);

                await con.OpenAsync();

                await cmd.ExecuteNonQueryAsync();
            }
        }
    }
}


using MyWebApi.Services;
using System.Threading.Tasks;
using System.Web.Http;

namespace MyWebApi.Controllers
{
    [RoutePrefix("api/quote")]
    public class QuoteController : ApiController
    {
        private readonly QuoteCacheService _service;

        public QuoteController()
        {
            _service = new QuoteCacheService();
        }

        [HttpPost]
        [Route("save/{quoteNo}")]
        public async Task<IHttpActionResult> Save(string quoteNo)
        {
            await _service.SaveAsync(quoteNo);

            return Ok("Saved");
        }

        [HttpGet]
        [Route("exists/{quoteNo}")]
        public async Task<IHttpActionResult> Exists(string quoteNo)
        {
            bool exists =
                await _service.ExistsAsync(quoteNo);

            return Ok(exists);
        }

        [HttpDelete]
        [Route("remove/{quoteNo}")]
        public async Task<IHttpActionResult> Remove(string quoteNo)
        {
            await _service.RemoveAsync(quoteNo);

            return Ok("Removed");
        }
    }
}
