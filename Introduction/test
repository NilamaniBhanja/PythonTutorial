using Microsoft.Extensions.Caching.Distributed;
using Microsoft.Extensions.Caching.SqlServer;
using Microsoft.Extensions.DependencyInjection;

public class WebApiApplication : System.Web.HttpApplication
{
    public static IServiceProvider ServiceProvider { get; private set; }

    protected void Application_Start()
    {
        var services = new ServiceCollection();

        services.AddDistributedSqlServerCache(options =>
        {
            options.ConnectionString = "Your_SQL_Server_Connection_String";
            options.SchemaName = "dbo";
            options.TableName = "CacheTable";
        });

        ServiceProvider = services.BuildServiceProvider();
        // Standard Web API config follows...
    }
}

using System;
using System.Threading.Tasks;
using Microsoft.Extensions.Caching.Distributed;
using System.Text;

public class QuoteCacheService
{
    private readonly IDistributedCache _cache;

    public QuoteCacheService(IDistributedCache cache)
    {
        _cache = cache;
    }

    public async Task<bool> IsDuplicateQuoteAsync(string quoteNumber)
    {
        // Try to get the quote from SQL cache
        var cachedValue = await _cache.GetAsync(quoteNumber);

        if (cachedValue != null)
        {
            // Quote already exists in cache
            return true;
        }

        // Quote is new. Store it with an expiration time (e.g., 24 hours)
        var options = new DistributedCacheEntryOptions()
            .SetAbsoluteExpiration(TimeSpan.FromHours(24));

        // Storing a simple "1" as a byte array to indicate presence
        await _cache.SetAsync(quoteNumber, Encoding.UTF8.GetBytes("1"), options);

        return false;
    }
}


using System.Net;
using System.Net.Http;
using System.Threading.Tasks;
using System.Web.Http;
using Microsoft.Extensions.Caching.Distributed;
using Microsoft.Extensions.DependencyInjection;

public class QuoteController : ApiController
{
    private readonly QuoteCacheService _quoteService;

    public QuoteController()
    {
        // Resolving from our ServiceProvider defined in Global.asax
        var cache = WebApiApplication.ServiceProvider.GetRequiredService<IDistributedCache>();
        _quoteService = new QuoteCacheService(cache);
    }

    [HttpPost]
    [Route("api/quotes/process")]
    public async Task<IHttpActionResult> ProcessQuote([FromBody] QuoteRequest request)
    {
        if (string.IsNullOrEmpty(request.QuoteNumber))
            return BadRequest("Quote number is required.");

        bool isDuplicate = await _quoteService.IsDuplicateQuoteAsync(request.QuoteNumber);

        if (isDuplicate)
        {
            // Reject the second request
            return Content(HttpStatusCode.Conflict, "Duplicate request: This quote number has already been processed.");
        }

        // Continue with your business logic...
        return Ok("Quote processed successfully.");
    }
}

using System;
using System.Text;
using System.Threading.Tasks;
using Microsoft.Extensions.Caching.SqlServer;
using Microsoft.Extensions.Caching.Distributed;
using Microsoft.Extensions.Options;

public static class QuoteLockManager
{
    private static readonly IDistributedCache _cache;

    static QuoteLockManager()
    {
        // Manual configuration without Dependency Injection
        var options = new SqlServerCacheOptions
        {
            ConnectionString = "Your_SQL_Connection_String_Here",
            SchemaName = "dbo",
            TableName = "CacheTable"
        };

        // We wrap options in a simple Options class to satisfy the constructor
        _cache = new SqlServerCache(Options.Create(options));
    }

    public static async Task<bool> IsDuplicateAndLock(string quoteNumber)
    {
        if (string.IsNullOrWhiteSpace(quoteNumber)) return false;

        // 1. Try to retrieve the quote number
        var data = await _cache.GetAsync(quoteNumber);

        if (data != null)
        {
            // Data exists, so this is a duplicate request
            return true; 
        }

        // 2. If it doesn't exist, save it to "lock" it
        // Set it to expire after a certain time (e.g., 10 minutes or 24 hours)
        var cacheOptions = new DistributedCacheEntryOptions
        {
            AbsoluteExpirationRelativeToNow = TimeSpan.FromHours(24)
        };

        // Save a dummy value (like "1") to mark this quote as "in use"
        byte[] dummyValue = Encoding.UTF8.GetBytes("1");
        await _cache.SetAsync(quoteNumber, dummyValue, cacheOptions);

        return false;
    }
}
public class QuoteRequest
{
    public string QuoteNumber { get; set; }
}
