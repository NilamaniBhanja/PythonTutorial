DECLARE @AgentID NUMERIC(18,0)
DECLARE @ProductID INT = 0
DECLARE @businessID INT
DECLARE @AgentCodeID NUMERIC(18,0)

-- Get ProductID
IF @ProductCode <> ''
BEGIN
    SELECT @ProductID = Id
    FROM MASProduct
    WHERE Code = @ProductCode
END

-- Get BusinessID
SELECT @businessID = Id
FROM MASVehicleBusinessType
WHERE Value = @BusinessType

-- Get AgentCodeID
SELECT TOP 1 @AgentCodeID = UserID
FROM tblUserExt
WHERE IMDCode = @IMDCode
AND IsActive = 1
ORDER BY UserExtID DESC


------------------------------------------
-- Handle Multiple AgentIDs if ProductID=0
------------------------------------------

DECLARE @AgentList TABLE (AgentID NUMERIC(18,0))

IF @ProductID = 0
BEGIN
    INSERT INTO @AgentList (AgentID)
    SELECT ID
    FROM AgentParameters
    WHERE AgentID = @AgentCodeID
END
ELSE
BEGIN
    INSERT INTO @AgentList (AgentID)
    SELECT ID
    FROM AgentParameters
    WHERE AgentID = @AgentCodeID
    AND ProductID = @ProductID
END


------------------------------------------
-- Update Existing Records
------------------------------------------

UPDATE M
SET IsNewBRMS = @IsNewBRMS
FROM MasAddonBundlingBusiness M
JOIN @AgentList A
    ON M.AgentID = A.AgentID
WHERE M.BusinessID = @businessID


------------------------------------------
-- Insert Missing Records
------------------------------------------

INSERT INTO MasAddonBundlingBusiness (BusinessID, AgentID, IsNewBRMS)
SELECT @businessID, A.AgentID, @IsNewBRMS
FROM @AgentList A
WHERE NOT EXISTS
(
    SELECT 1
    FROM MasAddonBundlingBusiness M
    WHERE M.BusinessID = @businessID
    AND M.AgentID = A.AgentID
)
